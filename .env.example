# Copy this file to .env and fill in your real values.
# In Replit, use the "Secrets" tab instead of a .env file for anything sensitive.

# --- Database (Replit Postgres / Neon) ---
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Paystack (NGN payments) ---
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --- Lemon Squeezy or Gumroad webhook secret (USD digital sales) ---
LEMONSQUEEZY_WEBHOOK_SECRET=
GUMROAD_WEBHOOK_SECRET=

# --- Email (Brevo / SendinBlue free tier, or any SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
FROM_EMAIL=hello@shepherdtech.com

# --- App ---
APP_BASE_URL=https://shepherdtech.replit.app
PORT=3000
